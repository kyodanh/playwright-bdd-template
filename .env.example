# =============================================================================
# MẪU CẤU HÌNH MÔI TRƯỜNG — LAYER 4 (Config)
# Copy file này thành .env.dev / .env.staging rồi điền giá trị thật.
# Các file .env.* (trừ .env.example) đã được .gitignore — KHÔNG commit secrets.
#
#   cp .env.example .env.dev
# =============================================================================

# URL gốc của ứng dụng đang test
BASE_URL=https://qassit.pages.dev

# Đường dẫn trang đăng nhập (tương đối so với BASE_URL)
LOGIN_PATH=/

# Channel trình duyệt:
#   để TRỐNG → Chromium (khuyến nghị cho CI)
#   msedge   → Microsoft Edge (local)
#   chrome   → Google Chrome (local)
BROWSER_CHANNEL=

# ---- Tài khoản test ---------------------------------------------------------
# Quy ước: ACCOUNT_<TÊN>_USERNAME / ACCOUNT_<TÊN>_PASSWORD
# Feature file chỉ tham chiếu tên "admin" — credentials nằm ở đây.
ACCOUNT_ADMIN_USERNAME=admin@gmail.com
ACCOUNT_ADMIN_PASSWORD=Admin@123
