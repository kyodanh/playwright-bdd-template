{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@config/*": ["./config/*"]
    }
  },
  "include": [
    "tests/**/*.ts",
    "config/**/*.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", ".features-gen"]
}
