{
  "name": "playwright-bdd-template",
  "version": "1.0.0",
  "description": "BDD Playwright automation template — BDD + POM + TypeScript",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "gen:examples": "node scripts/genExamples.js",
    "bddgen": "npm run gen:examples && npx bddgen",
    "test": "npx playwright test --headed",
    "testless": "npx playwright test",
    "tag": "npx playwright test --grep",
    "zip": "node zip-report.js"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "@playwright/test": "^1.51.0",
    "@types/node": "^22.13.1",
    "playwright": "^1.51.1",
    "playwright-bdd": "^9.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "bdd-playwright-core": "file:../bdd-playwright-core",
    "dotenv": "16.6.1"
  }
}
